{
  "name": "opencast",
  "version": "0.1.0",
  "description": "ShareFrame local-first screen recorder and private sharing prototype.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Martin123132/opencast.git"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "dev:e2e": "concurrently -k -n api,web -c cyan,green \"npm.cmd run dev:api\" \"npm.cmd run dev:web -- --port 5181 --strictPort\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "tsx --test tests/*.test.ts",
    "test:e2e": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "concurrently": "^10.0.3",
    "fastify": "^5.8.5",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
